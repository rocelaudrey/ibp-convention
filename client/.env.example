# Data source: "local" uses localStorage, "api" uses the REST backend
VITE_API_MODE=local

# When VITE_API_MODE=api, where to send requests.
# Leave empty in dev (Vite proxies /api → http://localhost:4000).
# In production set to your deployed server URL, e.g. https://api.yourdomain.com
VITE_API_URL=

# Admin password for the simple gate (local mode only).
# In API mode the server's ADMIN_PASSWORD is the source of truth.
VITE_ADMIN_PASSWORD=ibpadmin2026
