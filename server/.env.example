# Port the Express server listens on
PORT=4000

# MongoDB connection string (Atlas or local)
# Example Atlas URI:
#   mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ibp_convention?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ibp_convention

# Bootstrap super_admin — used only if the users collection has no super_admin yet.
# Sign in with these credentials on first boot, then change the password from the
# Users tab. After a super_admin exists, these values are ignored.
BOOTSTRAP_SUPER_USERNAME=admin
BOOTSTRAP_SUPER_PASSWORD=changeme-on-first-login

# Used to sign JWTs returned at login. Use a long random string in production.
JWT_SECRET=replace-with-a-long-random-string

# Comma-separated list of allowed CORS origins.
# Example: https://convention.ibpnorth.org,http://localhost:5173
CORS_ORIGINS=http://localhost:5173
